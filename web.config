<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- API: /api/auth/* ou /api/posts/* → api/index.php -->
        <rule name="API Rewrite" stopProcessing="true">
          <match url="^api/(auth|posts)(/(.*))?$" />
          <action type="Rewrite" url="api/index.php" appendQueryString="true" />
        </rule>
        <!-- Uploads: /api/uploads/* → manter como está -->
        <rule name="Uploads Passthrough" stopProcessing="true">
          <match url="^api/uploads/(.*)$" />
          <action type="None" />
        </rule>
      </rules>
    </rewrite>
    <defaultDocument>
      <files>
        <add value="index.html" />
        <add value="index.php" />
      </files>
    </defaultDocument>
  </system.webServer>
</configuration>